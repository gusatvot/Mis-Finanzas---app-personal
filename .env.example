# ─────────────────────────────────────────────────────────────
# Variables de entorno para producción (Vercel)
# ─────────────────────────────────────────────────────────────
# Copiá estos valores en Vercel → Settings → Environment Variables
# Importante: NUNCA subas el .env real a git. Este archivo es solo documentación.

# URL de conexión a MongoDB Atlas (la misma que usamos en desarrollo)
DATABASE_URL="mongodb+srv://finanzas-app:TU_PASSWORD@cluster0.xxxxx.mongodb.net/finanzas?retryWrites=true&w=majority&appName=Cluster0"

# Secret para firmar los JWT de NextAuth (generá uno nuevo con: openssl rand -base64 32)
NEXTAUTH_SECRET="pegá-acá-un-secret-largo-y-aleatorio"

# URL pública de tu app en Vercel (te la da Vercel después del primer deploy)
# Ejemplo: https://mis-finanzas.vercel.app
NEXTAUTH_URL="https://TU-DOMINIO.vercel.app"
